POSTGRES_DB=eris
POSTGRES_USER=eris
POSTGRES_PASSWORD=change_me
REDIS_PASSWORD=change_me
SECRET_KEY=change_me
OPENROUTER_API_KEY=sk-or-v1_xxx
TELEGRAM_BOT_TOKEN=1234567890:AA_xxx
# D2-2: 上游 LLM 失败时是否回退为 echo（演示 / 降级用）
LLM_ECHO_FALLBACK=0
# D3-3: 记忆写入总开关；false / 0 时 memory writer 直接 noop（演示 / 调试用）
MEMORY_WRITE_ENABLED=true
# D3-3: 记忆评分用的 LLM 模型；留空走 llm.chat 主备路由
LLM_MEMORY_MODEL=openai/gpt-4o-mini
# D3-3: importance 阈值，评分 ≥ 此值才入 memories 表（默认 5）
MEMORY_IMPORTANCE_THRESHOLD=5
# D4-2：主对话路径是否检索记忆写入 L6（需 db + OPENAI_API_KEY 才有语义检索；关=不占 embed）
MEMORY_RETRIEVE_IN_PROMPT=false
# D4-2：注入条数 / 候选池（与 MemoryRetrieveRequest 默认一致）
MEMORY_RETRIEVE_TOP_K=10
MEMORY_RETRIEVE_K_CANDIDATES=30
# D4-3/D4-4：generate_reply 主路径刷新 loneliness_score（详见 D4-3_LONELINESS_SCORING.md）
LONELINESS_REFRESH_ENABLED=true
LONELINESS_LOOKBACK_DAYS=30
LONELINESS_MEMORY_CAP=40
LONELINESS_PER_MEMORY_CLAMP=12
LONELINESS_GLOBAL_DELTA_CLAMP=20
LONELINESS_DECAY_FACTOR=0.08
LONELINESS_BASELINE=35
LONELINESS_MIN_UPDATE_DELTA=0.05
LONELINESS_UTTERANCE_ENABLED=true
LONELINESS_UTTERANCE_MAX_DELTA=10
# D4-4 剩余：画像分 worker（initiation_score + min-only trigger_threshold）；默认关，生产显式打开
SCORE_WORKER_ENABLED=false
SCORE_WORKER_POLL_SECONDS=120
# D8-2: APScheduler max_instances for profile_score_worker tick（每进程）；与 advisory lock 6300413 配合
SCORE_WORKER_SCHEDULER_MAX_INSTANCES=1
SCORE_INITIATION_LOOKBACK_DAYS=7
SCORE_INITIATION_CAP_MESSAGES=40
SCORE_PROFILE_MIN_UPDATE_DELTA=0.05
TRIGGER_THRESHOLD_BASE=65
TRIGGER_THRESHOLD_PIVOT=35
TRIGGER_THRESHOLD_K=0.15
TRIGGER_THRESHOLD_FLOOR=50
TRIGGER_THRESHOLD_CEIL=82
# D3-4: 异步 embedding worker 总开关；关掉时新 memories.embedding 一直 NULL
EMBEDDING_WORKER_ENABLED=true
# D3-4: 直连 OpenAI（不走 OpenRouter）的 key，专给 embeddings 用
# 没配置时 worker 不启动，新 memories 的 embedding 保持 NULL；旧行不变
OPENAI_API_KEY=sk-xxx
# D3-4: 1536 维必须与 memories.embedding vector(1536) 对齐；改前需迁移 schema
EMBEDDING_MODEL=text-embedding-3-small
# D3-4: 一次拉多少条；不超过 64 比较稳
EMBEDDING_BATCH_SIZE=32
# D3-4: 轮询间隔，秒，最低 5
EMBEDDING_POLL_SECONDS=30
# D8-2: OpenAI embeddings HTTP 超时（秒）
EMBEDDING_HTTP_TIMEOUT_SECONDS=20
# D8-2: embedding_worker 调度器 APScheduler max_instances（每进程）；DB 仍由 advisory lock 6300410 串行
EMBEDDING_SCHEDULER_MAX_INSTANCES=1
# D6-3: 静默重激活总开关；置 1 后 admin /silent-reactivation/run 才会真的扫库
SILENT_REACTIVATION_ENABLED=0
# D6-3 调度：crontab 形式（分 时 日 月 周，UTC）。默认每天 UTC 02:00。
# 仅在 SILENT_REACTIVATION_ENABLED=1 时生效；多 worker / 多实例靠 pg_advisory_lock 防重复。
SILENT_REACTIVATION_CRON=0 2 * * *
ENV=production
# D6-1 / D6-2 Stripe（生产置真实值；任一缺失会让对应路由 503/400）
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_before_use
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx
# D6-1: Stripe Checkout 跳转 URL（{CHECKOUT_SESSION_ID} 由 Stripe 自动替换）
STRIPE_SUCCESS_URL=https://hugme2.com/payment/success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=https://hugme2.com/payment/cancel
