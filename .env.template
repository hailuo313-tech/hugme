# ERIS environment template (C-03)
# Copy to .env and fill values. Never commit .env.
# See also: .env.example (docker-compose oriented)

# ── Core ─────────────────────────────────────────────────────────────
SECRET_KEY=change_me_long_random_string
ENV=development
DATABASE_URL=postgresql+asyncpg://eris:change_me@localhost:5432/eris
REDIS_URL=redis://:change_me@localhost:6379/0

# ── MTProto / Telethon (真人 Userbot，W2+ 接入) ───────────────────────
# https://my.telegram.org/apps → api_id / api_hash
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_from_my_telegram_org
# 多账号池：逗号分隔的 Telethon StringSession（明文仅 dev；生产用加密存储）
TELEGRAM_SESSION_STRINGS=
# Fernet 密钥，加密落库的 Session（生成: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
TELEGRAM_SESSION_FERNET_KEY=
# 可选：Session 文件目录（与 STRING 二选一或并存）
TELEGRAM_SESSION_DIR=./data/telegram_sessions

# ── 兼容 Bot Webhook（旧路径 / 降级）──────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ── LLM（Novita 主 / OpenRouter 备）──────────────────────────────────
NOVITA_API_KEY=your_novita_api_key
LLM_API_BASE_URL=https://api.novita.ai/openai/v1
LLM_PRIMARY_MODEL=deepseek/deepseek-v3-0324
LLM_FALLBACK_MODEL=deepseek/deepseek-r1
OPENROUTER_API_KEY=
LLM_ECHO_FALLBACK=0

# ── Memory / Embedding ───────────────────────────────────────────────
MEMORY_WRITE_ENABLED=true
LLM_MEMORY_MODEL=deepseek/deepseek-v3-0324
MEMORY_IMPORTANCE_THRESHOLD=5
EMBEDDING_WORKER_ENABLED=true
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BATCH_SIZE=32
EMBEDDING_POLL_SECONDS=30

# ── Stripe ───────────────────────────────────────────────────────────
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_SUCCESS_URL=https://hugme2.com/payment/success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=https://hugme2.com/payment/cancel

# ── Ops / compose（与 .env.example 对齐）────────────────────────────
POSTGRES_DB=eris
POSTGRES_USER=eris
POSTGRES_PASSWORD=change_me
REDIS_PASSWORD=change_me
SILENT_REACTIVATION_ENABLED=0
SILENT_REACTIVATION_CRON=0 2 * * *
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_before_use
DISCORD_WEBHOOK_URL=
