# =============================================================================
# ERIS .env.template (C-03)
# =============================================================================
# 1. 复制:  copy .env.template .env   (Windows)  |  cp .env.template .env
# 2. 阅读:  docs/MTProto_ENV_SETUP.md
# 3. 自检:  .\scripts\check-mtproto-env.ps1  |  bash scripts/check-mtproto-env.sh
# 勿提交 .env。完整 compose 变量见 .env.example
# =============================================================================

# ── Core ─────────────────────────────────────────────────────────────────────
SECRET_KEY=change_me_long_random_string
ENV=development
DATABASE_URL=postgresql+asyncpg://eris:change_me@localhost:5432/eris
REDIS_URL=redis://:change_me@localhost:6379/0

# ── MTProto / Telethon（C-03 必填区；W2 Userbot 接入）────────────────────────
# 申请: https://my.telegram.org/apps
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Fernet: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TELEGRAM_SESSION_FERNET_KEY=
# 逗号分隔 StringSession（dev）；生产建议加密落库 + Fernet
TELEGRAM_SESSION_STRINGS=
# 可选：每账号 .session 文件目录（与 STRING 二选一或并存）
TELEGRAM_SESSION_DIR=./data/telegram_sessions
# W2 前保持 0；Telethon 运行时改为 1
MTProto_ENABLED=0
TELEGRAM_DEVICE_MODEL=ERIS
TELEGRAM_SYSTEM_VERSION=1.0

# ── Telegram Bot（Webhook / 通知降级；与 MTProto 独立）──────────────────────
TELEGRAM_BOT_TOKEN=

# ── LLM（Novita 主 / OpenRouter 备）──────────────────────────────────────────
NOVITA_API_KEY=
LLM_API_BASE_URL=https://api.novita.ai/openai/v1
LLM_PRIMARY_MODEL=deepseek/deepseek-v3-0324
LLM_FALLBACK_MODEL=deepseek/deepseek-r1
OPENROUTER_API_KEY=
LLM_ECHO_FALLBACK=0
LLM_MEMORY_MODEL=openai/gpt-4o-mini
MEMORY_WRITE_ENABLED=true
MEMORY_IMPORTANCE_THRESHOLD=5
MEMORY_RETRIEVE_IN_PROMPT=false

# P2-06: level engine thresholds. Runtime env values override config/level_thresholds.json.
LEVEL_S_MIN_SPEND=200
LEVEL_A_MIN_SPEND=99
LEVEL_B_MIN_SPEND=0
LEVEL_VIP_LEVEL_A_MIN=1
LEVEL_T1_DEFAULT=B
LEVEL_T2_DEFAULT=C
LEVEL_T3_DEFAULT=C
LEVEL_UNKNOWN_DEFAULT=C

# ── Embedding / OpenAI ───────────────────────────────────────────────────────
EMBEDDING_WORKER_ENABLED=true
EMBEDDING_API_KEY=
EMBEDDING_API_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BATCH_SIZE=32
EMBEDDING_POLL_SECONDS=30

# ── 内容安全（生产建议打开，见 .env.example）────────────────────────────────
CONTENT_SAFETY_ENABLED=0
CONTENT_SAFETY_MODERATION_ENABLED=1

# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=https://hugme2.com/payment/success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=https://hugme2.com/payment/cancel

# ── Docker Compose（与 .env.example 对齐）────────────────────────────────────
POSTGRES_DB=eris
POSTGRES_USER=eris
POSTGRES_PASSWORD=change_me
REDIS_PASSWORD=change_me
SILENT_REACTIVATION_ENABLED=1
SILENT_REACTIVATION_CRON=0 2 * * *
NOTIFICATION_SENDER_ENABLED=1
NOTIFICATION_SENDER_POLL_SECONDS=20
NOTIFICATION_SENDER_SCHEDULER_MAX_INSTANCES=1
MESSAGE_SCHEDULE_ENABLED=1
MESSAGE_SCHEDULE_POLL_SECONDS=20
MESSAGE_SCHEDULE_SCHEDULER_MAX_INSTANCES=1
AUTO_DELIVERY_ENABLED=1
AUTO_DELIVERY_POLL_SECONDS=20
AUTO_DELIVERY_SCHEDULER_MAX_INSTANCES=1
ARCHIVE_WORKER_ENABLED=0
ARCHIVE_WORKER_POLL_SECONDS=30
ARCHIVE_WORKER_SCHEDULER_MAX_INSTANCES=1
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_before_use
DISCORD_WEBHOOK_URL=
